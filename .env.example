# Mail2WhatsApp AI System Environment Variables

# LLM Provider Configuration
# Choose 'openai', 'openrouter', or 'google'
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openai_or_openrouter_or_gemini_api_key
# Default model: 'gpt-4o-mini' for openai, 'gemini-1.5-flash' for google, or any model slug for openrouter
LLM_MODEL=openrouter/free

# Google OAuth 2.0 Credentials (Gmail API)
# Create credentials in Google Cloud Console with Gmail API enabled
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# JWT Security
# Generate a secure random string (e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_signing_secret

# WhatsApp Cloud API Credentials
# Create a WhatsApp Business developer account at developers.facebook.com
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
